import sys
sys.path.insert(0, '.')

import pytest
import json
from pathlib import Path

from app.chunker import chunk_text


class TestChunkText:
    """Тесты для функции chunk_text"""
    
    def test_empty_text(self):
        """Пустой текст возвращает пустой список"""
        assert chunk_text("") == []
    
    def test_none_text(self):
        """None текст безопасно обрабатывается"""
        result = chunk_text(None) if None else []
        assert result == []
    
    def test_short_text(self):
        """Короткий текст возвращает один чанк"""
        text = "Короткий текст для теста"
        chunks = chunk_text(text, chunk_size=100, overlap=0)
        assert len(chunks) >= 1
        assert chunks[0] == text
    
    def test_long_text_splits(self):
        """Длинный текст разбивается на несколько чанков"""
        text = "a" * (500 + 200)
        chunks = chunk_text(text, chunk_size=500, overlap=0)
        assert len(chunks) >= 2
    
    def test_chunk_size_not_exceeded(self):
        """Чанки не превышают CHUNK_SIZE"""
        text = "x" * (500 * 3)
        chunks = chunk_text(text, chunk_size=500, overlap=50)
        
        for chunk in chunks:
            assert len(chunk) <= 500 + 10
    
    def test_paragraph_preservation(self):
        """Абзацы сохраняются в чанках"""
        text = "Первый абзац.\n\nВторой абзац.\n\nТретий абзац."
        chunks = chunk_text(text, chunk_size=200, overlap=0)
        
        # Должно быть 3 чанка
        assert len(chunks) == 3
    
    def test_no_empty_chunks(self):
        """Нет пустых чанков"""
        text = "Строка 1\n\n\n\nСтрока 2"
        chunks = chunk_text(text, chunk_size=CHUNK_SIZE, overlap=CHUNK_OVERLAP)
        
        for chunk in chunks:
            assert chunk.strip() != ""
    
    def test_overlap_between_chunks(self):
        """Перекрытие между чанками работает"""
        text = "a" * 250
        chunks = chunk_text(text, chunk_size=100, overlap=20)
        
        if len(chunks) > 1:
            # Последние 20 символов первого чанка должны быть в начале второго
            overlap_part = chunks[0][-20:]
            assert overlap_part in chunks[1][:25]
    
    def test_very_long_paragraph_splits(self):
        """Очень длинный абзац разбивается на несколько чанков"""
        # Создаём один длинный абзац (без переносов строк)
        text = "a" * (500 * 3)
        chunks = chunk_text(text, chunk_size=500, overlap=0)
        
        assert len(chunks) >= 2
        assert all(len(c) <= 500 for c in chunks)


class TestChunksFile:
    """Тесты для файла chunks.jsonl"""
    
    def test_chunks_file_exists(self):
        """Файл chunks.jsonl существует"""
        chunks_path = "chunks.jsonl"
        assert chunks_path.exists(), "chunks.jsonl не найден. Сначала выполните chunking"
    
    def test_chunks_have_required_fields(self):
        """Каждый чанк имеет все необходимые поля"""
        chunks_path = "chunks.jsonl"
        
        if not chunks_path.exists():
            pytest.skip("chunks.jsonl не найден")
        
        required_fields = ['chunk_id', 'doc_id', 'text', 'chunk_index']
        
        with open(chunks_path, 'r', encoding='utf-8') as f:
            first_line = f.readline()
            if first_line.strip():
                chunk = json.loads(first_line)
                for field in required_fields:
                    assert field in chunk, f"Отсутствует поле {field}"
    
    def test_chunk_ids_unique(self):
        """Все chunk_id уникальны"""
        chunks_path = "chunks.jsonl"
        
        if not chunks_path.exists():
            pytest.skip("chunks.jsonl не найден")
        
        chunk_ids = []
        with open(chunks_path, 'r', encoding='utf-8') as f:
            for line in f:
                if line.strip():
                    chunk = json.loads(line)
                    chunk_ids.append(chunk.get('chunk_id'))
        
        assert len(chunk_ids) == len(set(chunk_ids)), "Найдены дублирующиеся chunk_id"
    
    def test_chunk_count_gt_1000(self):
        """Количество чанков больше 1000 (для оценки 10/10)"""
        chunks_path = "chunks.jsonl"
        
        if not chunks_path.exists():
            pytest.skip("chunks.jsonl не найден")
        
        with open(chunks_path, 'r', encoding='utf-8') as f:
            line_count = sum(1 for line in f if line.strip())
        
        assert line_count >= 1000, f"Чанков {line_count}, нужно минимум 1000"


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
