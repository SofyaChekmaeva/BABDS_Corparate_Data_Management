import json
from pathlib import Path

# Путь к файлу (если в корне или в data/processed/)
chunks_path = Path('chunks.jsonl')
# Загружаем чанки
chunks = []
with open(chunks_path, 'r', encoding='utf-8') as f:
    for line in f:
        if line.strip():
            chunks.append(json.loads(line))

print(f"📊 Загружено чанков: {len(chunks)}")

# тест 1 - структура чанков

print("="*50)
print("ТЕСТ 1: Структура чанков")
print("="*50)

required_fields = ['chunk_id', 'doc_id', 'text', 'chunk_index']
first_chunk = chunks[0]

for field in required_fields:
    if field in first_chunk:
        print(f"Поле '{field}' присутствует")
    else:
        print(f"Поле '{field}' ОТСУТСТВУЕТ")

print(f"Пример чанка:")
print(f"chunk_id: {first_chunk.get('chunk_id')}")
print(f"doc_id: {first_chunk.get('doc_id')}")
print(f"chunk_index: {first_chunk.get('chunk_index')}")
print(f"text (первые 150 символов): {first_chunk.get('text', '')[:150]}...")

# тест 2 - размеры чанков

print("="*50)
print("ТЕСТ 2: Размеры чанков")
print("="*50)

sizes = [len(c.get('text', '')) for c in chunks]

print(f"Минимальный размер: {min(sizes)} символов")
print(f"Максимальный размер: {max(sizes)} символов")
print(f"Средний размер: {sum(sizes)/len(sizes):.1f} символов")

# Проверка: все чанки не пустые
empty_chunks = [c for c in chunks if not c.get('text', '').strip()]
print(f"Пустых чанков: {len(empty_chunks)}")

# Проверка: чанки не слишком большие (разумный лимит 2000)
large_chunks = [c for c in chunks if len(c.get('text', '')) > 2000]
print(f"Чанков >2000 символов: {len(large_chunks)}")

# тест 3 - уникальность id

print("="*50)
print("ТЕСТ 3: Уникальность chunk_id")
print("="*50)

chunk_ids = [c.get('chunk_id') for c in chunks]
unique_ids = set(chunk_ids)

print(f"Всего чанков: {len(chunk_ids)}")
print(f"Уникальных ID: {len(unique_ids)}")

if len(chunk_ids) == len(unique_ids):
    print("Все chunk_id уникальны!")
else:
    print(f"Найдено дубликатов: {len(chunk_ids) - len(unique_ids)}")
    
    # Показываем дубликаты
    from collections import Counter
    duplicates = [id for id, count in Counter(chunk_ids).items() if count > 1]
    print(f"Дублирующиеся ID: {duplicates[:5]}")

# тест 4 - распределение чанков по документам

print("="*50)
print("ТЕСТ 4: Распределение по документам")
print("="*50)

from collections import Counter
doc_counts = Counter([c.get('doc_id') for c in chunks])

print(f"Всего документов: {len(doc_counts)}")
print(f"Среднее чанков на документ: {sum(doc_counts.values())/len(doc_counts):.1f}")
print(f"Максимум чанков в документе: {max(doc_counts.values())}")
print(f"Минимум чанков в документе: {min(doc_counts.values())}")

# Показываем топ-5 документов с наибольшим числом чанков
top_docs = doc_counts.most_common(5)
print(f"Топ-5 документов по числу чанков:")
for doc_id, count in top_docs:
    print(f"   {doc_id}: {count} чанков")

# тест 5 - проверка chunk_index

print("="*50)
print("ТЕСТ 5: Проверка chunk_index")
print("="*50)

# Берём один документ и проверяем индексы
sample_doc_id = chunks[0].get('doc_id')
doc_chunks = [c for c in chunks if c.get('doc_id') == sample_doc_id]

print(f"Документ: {sample_doc_id}")
print(f"Количество чанков: {len(doc_chunks)}")

indices = [c.get('chunk_index') for c in doc_chunks]
expected_indices = list(range(len(doc_chunks)))

if indices == expected_indices:
    print("chunk_index идут по порядку (0, 1, 2, ...)")
else:
    print(f"Ожидалось: {expected_indices}")
    print(f"Получено: {indices}")

# тест 6 - поиск по ключевым словам

print("="*50)
print("ТЕСТ 6: Поиск по ключевым словам")
print("="*50)

def search_chunks(query, chunks, top_k=3):
    """Простой поиск по вхождению слов (без TF-IDF)"""
    query_words = set(query.lower().split())
    results = []
    
    for chunk in chunks:
        text = chunk.get('text', '').lower()
        score = sum(1 for word in query_words if word in text)
        if score > 0:
            results.append((chunk, score))
    
    results.sort(key=lambda x: x[1], reverse=True)
    return results[:top_k]

# Тестовые запросы
test_queries = [
    "не могу войти в аккаунт",
    "как изменить способ оплаты",
    "отменить подписку",
    "как приготовить борщ"  # off-topic
]

for query in test_queries:
    print(f"Запрос: '{query}'")
    results = search_chunks(query, chunks, top_k=2)
    
    if results:
        print(f"   Найдено чанков: {len(results)}")
        for chunk, score in results:
            print(f"   - doc_id={chunk.get('doc_id')}, score={score}")
            print(f"     {chunk.get('text', '')[:80]}...")
    else:
        print("Ничего не найдено")

# итоговый мини отчет

print("="*60)
print("ИТОГОВЫЙ ОТЧЁТ ПО ТЕСТАМ CHUNKING")
print("="*60)

results = {
    "Файл существует": chunks_path.exists(),
    "Количество чанков > 1000": len(chunks) > 1000,
    "Все поля присутствуют": all(field in chunks[0] for field in required_fields),
    "Нет пустых чанков": all(c.get('text', '').strip() for c in chunks),
    "chunk_id уникальны": len(chunks) == len(set([c.get('chunk_id') for c in chunks])),
    "Размер чанков ≤ 2000": all(len(c.get('text', '')) <= 2000 for c in chunks),
}

for test_name, passed in results.items():
    status = "✅" if passed else "❌"
    print(f"{status} {test_name}: {'Пройден' if passed else 'Провален'}")

score = sum(results.values()) / len(results) * 100
print(f"Общий результат: {score:.0f}% ({sum(results.values())}/{len(results)})")

if score == 100:
    print("Отлично! Все тесты пройдены!")
elif score >= 80:
    print("Хорошо, но есть мелкие проблемы")
else:
    print("Требуется доработка")
