import sys
sys.path.insert(0, '.')

import pytest
import json
from pathlib import Path

from app.retriever import Retriever, get_retriever, retrieve


class TestRetrieverInit:
    """Тесты инициализации ретривера"""
    
    def test_retriever_initializes(self):
        """Ретривер успешно инициализируется"""
        try:
            retriever = get_retriever()
            assert retriever is not None
        except Exception as e:
            pytest.fail(f"Ретривер не инициализировался: {e}")
    
    def test_chunks_metadata_loaded(self):
        """Метаданные чанков загружены"""
        retriever = get_retriever()
        assert len(retriever.chunks_metadata) > 0
        assert 'chunk_id' in retriever.chunks_metadata[0]
        assert 'doc_id' in retriever.chunks_metadata[0]


class TestRetrieval:
    """Тесты поиска"""
    
    def test_retrieve_returns_list(self):
        """retrieve возвращает список"""
        retriever = get_retriever()
        results = retriever.retrieve("тест")
        assert isinstance(results, list)
    
    def test_retrieve_top_k(self):
        """retrieve возвращает не более top_k результатов"""
        retriever = get_retriever()
        results = retriever.retrieve("не могу войти", top_k=3)
        assert len(results) <= 3
    
    def test_retrieve_has_required_fields(self):
        """Каждый результат имеет все необходимые поля"""
        retriever = get_retriever()
        results = retriever.retrieve("аккаунт", top_k=1)
        
        if results:
            r = results[0]
            required = ['text', 'doc_id', 'chunk_id', 'score', 'name']
            for field in required:
                assert field in r, f"Отсутствует поле {field}"
    
    def test_scores_in_range(self):
        """Score находится в диапазоне [0, 1]"""
        retriever = get_retriever()
        results = retriever.retrieve("проблема", top_k=3)
        
        for r in results:
            assert 0 <= r['score'] <= 1, f"Score вне диапазона: {r['score']}"
    
    def test_relevant_query_has_positive_scores(self):
        """Релевантный запрос даёт положительные scores"""
        retriever = get_retriever()
        results = retriever.retrieve("не могу войти в аккаунт", top_k=3)
        
        positive_scores = [r for r in results if r['score'] > 0]
        assert len(positive_scores) > 0
    
    def test_empty_query_returns_empty(self):
        """Пустой запрос возвращает пустой список"""
        retriever = get_retriever()
        results = retriever.retrieve("")
        assert results == []
    
    def test_retrieve_function_exists(self):
        """Функция retrieve (синглтон) работает"""
        results = retrieve("тест", top_k=2)
        assert isinstance(results, list)


class TestRetrievalQuality:
    """Тесты качества поиска"""
    
    def test_login_query_finds_login_issues(self):
        """Запрос о входе находит Login Issue"""
        retriever = get_retriever()
        results = retriever.retrieve("не могу войти", top_k=3)
        
        # Проверяем, что хотя бы один результат связан с логином
        login_keywords = ['login', 'аккаунт', 'пароль', 'войти', 'account', 'password']
        found = False
        
        for r in results:
            text_lower = r['text'].lower()
            name_lower = r['name'].lower()
            for kw in login_keywords:
                if kw in text_lower or kw in name_lower:
                    found = True
                    break
            if found:
                break
        
        assert found, "Не найдено результатов, связанных с проблемами входа"
    
    def test_payment_query_finds_payment_issues(self):
        """Запрос об оплате находит Payment Problem"""
        retriever = get_retriever()
        results = retriever.retrieve("изменить способ оплаты", top_k=3)
        
        payment_keywords = ['payment', 'платеж', 'оплат', 'card', 'credit']
        found = False
        
        for r in results:
            text_lower = r['text'].lower()
            name_lower = r['name'].lower()
            for kw in payment_keywords:
                if kw in text_lower or kw in name_lower:
                    found = True
                    break
            if found:
                break
        
        assert found, "Не найдено результатов, связанных с оплатой"
    
    def test_subscription_query_finds_subscription_issues(self):
        """Запрос о подписке находит Subscription Cancellation"""
        retriever = get_retriever()
        results = retriever.retrieve("отменить подписку", top_k=3)
        
        sub_keywords = ['subscription', 'подписк', 'cancel', 'отмен', 'refund']
        found = False
        
        for r in results:
            text_lower = r['text'].lower()
            name_lower = r['name'].lower()
            for kw in sub_keywords:
                if kw in text_lower or kw in name_lower:
                    found = True
                    break
            if found:
                break
        
        assert found, "Не найдено результатов, связанных с подпиской"


