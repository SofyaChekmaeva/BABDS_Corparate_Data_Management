import pickle
import json
from pathlib import Path
from typing import List, Dict, Any, Tuple

import numpy as np
import scipy.sparse as sp


class Retriever:

    def __init__(self, index_dir: Path = None, top_k: int = None, threshold: float = None):
        self.index_dir = index_dir
        self.top_k = top_k or 3
        self.threshold = threshold or 0.7

        # Загружаем векторизатор
        vectorizer_path = "vectorizer.pkl"
        if not vectorizer_path.exists():
            raise FileNotFoundError(f"Векторизатор не найден: {vectorizer_path}")

        with open(vectorizer_path, 'rb') as f:
            self.vectorizer = pickle.load(f)

        # Загружаем TF-IDF матрицу
        matrix_path = "matrix.npz"
        if not matrix_path.exists():
            raise FileNotFoundError(f"TF-IDF матрица не найдена: {matrix_path}")

        self.tfidf_matrix = sp.load_npz(matrix_path)

        # Загружаем метаданные чанков
        chunks_path = "chunks.jsonl"
        if not chunks_path.exists():
            raise FileNotFoundError(f"Метаданные чанков не найдены: {chunks_path}")

        self.chunks_metadata = []
        with open(chunks_path, 'r', encoding='utf-8') as f:
            for line in f:
                if line.strip():
                    self.chunks_metadata.append(json.loads(line))

        print(f"    Ретривер инициализирован:")
        print(f"   Чанков в индексе: {len(self.chunks_metadata)}")
        print(f"   top_k: {self.top_k}")
        print(f"   threshold: {self.threshold}")

    def retrieve(self, query: str, top_k: int = None) -> List[Dict[str, Any]]:
        if not query or not query.strip():
            return []

        k = top_k or self.top_k

        # Векторизуем запрос
        query_vec = self.vectorizer.transform([query])

        # Вычисляем косинусное сходство со всеми чанками
        # (query_vec @ matrix.T) даёт плотный массив сходств
        scores = np.array((query_vec @ self.tfidf_matrix.T).todense()).flatten()

        # Получаем индексы top-k чанков
        if len(scores) <= k:
            top_indices = np.argsort(scores)[::-1]
        else:
            top_indices = np.argpartition(scores, -k)[-k:]
            top_indices = top_indices[np.argsort(scores[top_indices])[::-1]]

        # Формируем результаты
        results = []
        for idx in top_indices:
            score = float(scores[idx])

            # Пропускаем чанки ниже порога
            if score < self.threshold:
                continue

            metadata = self.chunks_metadata[idx]

            # Пытаемся получить текст чанка из метаданных
            text = metadata.get('text', '')
            if not text:
                # Если текста нет в метаданных, нужно загрузить из chunks.jsonl
                # В нашем случае текста нет в index/chunks.jsonl, поэтому
                # будем хранить текст отдельно или загружать из processed
                text = f"[Чанк {metadata.get('chunk_id')}]"

            results.append({
                'text': text,
                'doc_id': metadata.get('doc_id', 'unknown'),
                'chunk_id': metadata.get('chunk_id', 'unknown'),
                'score': score,
                'name': metadata.get('name', '')
            })

        return results[:k]

    def retrieve_with_text(self, query: str, top_k: int = None) -> List[Tuple[str, float, Dict]]:
        results = self.retrieve(query, top_k)
        return [(r['text'], r['score'], {'doc_id': r['doc_id'], 'chunk_id': r['chunk_id']})
                for r in results]


# Функция для быстрого поиска (без создания экземпляра класса)
_retriever_instance = None


def get_retriever() -> Retriever:
    """Синглтон для получения экземпляра ретривера."""
    global _retriever_instance
    if _retriever_instance is None:
        _retriever_instance = Retriever()
    return _retriever_instance


def retrieve(query: str, top_k: int = None) -> List[Dict[str, Any]]:
    return get_retriever().retrieve(query, top_k)
