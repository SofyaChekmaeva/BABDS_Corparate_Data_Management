import sys
import streamlit as st
from pathlib import Path

# Добавляем путь для импорта
sys.path.insert(0, '.')

from app.retriever import get_retriever
from app.generator import generate_answer, format_final_response


# Настройка страницы
st.set_page_config(
    page_title="SupportRAG — Умная поддержка клиентов",
    page_icon="🎯",
    layout="wide",
    initial_sidebar_state="expanded"
)


# Заголовок
st.title("🎯 SupportRAG")
st.markdown("Умная система поиска и генерации ответов на основе обращений в службу поддержки")


# Функция проверки наличия индекса
def check_index_exists() -> bool:
    """Проверяет, собран ли индекс."""
    vectorizer_path = "vectorizer.pkl"
    matrix_path = "matrix.npz"
    chunks_path = "chunks.jsonl"
    return all(p.exists() for p in [vectorizer_path, matrix_path, chunks_path])


# Инициализация ретривера (если индекс есть)
@st.cache_resource
def init_retriever():
    """Инициализирует ретривер с кешированием."""
    if check_index_exists():
        try:
            return get_retriever()
        except Exception as e:
            st.error(f"Ошибка загрузки индекса: {e}")
            return None
    return None


# Боковая панель
with st.sidebar:
    st.header("⚙️ Настройки")
    
    # Информация об индексе
    st.subheader("📊 Статус индекса")
    if check_index_exists():
        st.success("✅ Индекс загружен")
        
        # Показываем информацию об индексе
        try:
            import pickle
            import scipy.sparse as sp
            
            matrix_path = "matrix.npz"
            if matrix_path.exists():
                matrix = sp.load_npz(matrix_path)
                st.info(f"📄 Чанков в индексе: {matrix.shape[0]}")
                st.info(f"🔤 Уникальных термов: {matrix.shape[1]}")
        except Exception:
            pass
    else:
        st.error("❌ Индекс не найден")
        st.warning("Пожалуйста, выполните сборку индекса:\n```bash\npython scripts/build_index.py\n```")
    
    st.divider()
    
    # Настройки поиска
    st.subheader("🔍 Параметры поиска")
    top_k = st.slider("Количество результатов (top_k)", 
                      min_value=1, max_value=10, value=3)
    threshold = st.slider("Порог релевантности (threshold)", 
                          min_value=0.0, max_value=1.0, value=0.3, step=0.05)
    
    st.divider()
    
    # Demo-вопросы
    st.subheader("📋 Demo-вопросы")
    
    demo_queries = [
        "🔐 Не могу войти в аккаунт",
        "💳 Как изменить способ оплаты?",
        "❌ Отменить подписку",
        "💰 Вернуть деньги за услугу",
        "🍲 Как приготовить борщ? (отказ)"
    ]
    
    for q in demo_queries:
        if st.button(q, use_container_width=True):
            st.session_state.query = q.replace("🔐 ", "").replace("💳 ", "").replace("❌ ", "").replace("💰 ", "").replace(" (отказ)", "")
            st.rerun()


# Основная область
st.subheader("💬 Задайте вопрос службе поддержки")

# Поле ввода
query = st.text_input(
    "Ваш вопрос:",
    placeholder="Например: Не могу войти в аккаунт, подскажите что делать?",
    key="query_input",
    value=st.session_state.get("query", "")
)

# Кнопка отправки
col1, col2 = st.columns([1, 5])
with col1:
    search_button = st.button("🔍 Найти ответ", type="primary", use_container_width=True)


# Обработка запроса
if search_button and query:
    # Проверяем наличие индекса
    if not check_index_exists():
        st.error("❌ Индекс не собран! Пожалуйста, выполните сборку индекса перед использованием.")
        st.stop()
    
    # Инициализируем ретривер
    retriever = init_retriever()
    if retriever is None:
        st.error("❌ Не удалось загрузить ретривер")
        st.stop()
    
    # Показываем спиннер во время поиска
    with st.spinner("🔍 Поиск ответа..."):
        # Поиск релевантных чанков
        results = retriever.retrieve(query, top_k=top_k)
        
        # Генерация ответа
        generation = generate_answer(query, results, threshold=threshold)
        final_answer = format_final_response(generation)
    
    # Отображаем ответ
    st.markdown("---")
    st.subheader("📝 Ответ")
    st.markdown(final_answer)
    
    # Отображаем найденные чанки
    if results:
        st.subheader("📚 Найденные фрагменты")
        
        for i, r in enumerate(results, 1):
            # Показываем результат только если score >= threshold
            if r['score'] >= threshold:
                with st.expander(f"Результат {i}: {r['name']} (score: {r['score']:.3f})"):
                    st.markdown(f"**Doc ID:** `{r['doc_id']}`")
                    st.markdown(f"**Название:** {r['name']}")
                    st.markdown(f"**Релевантность:** {r['score']:.3f}")
                    st.markdown("**Текст фрагмента:**")
                    st.text(r['text'][:800] + ("..." if len(r['text']) > 800 else ""))
            else:
                with st.expander(f"Результат {i}: {r['name']} (score: {r['score']:.3f}) — ниже порога"):
                    st.warning(f"Этот фрагмент имеет score {r['score']:.3f} ниже порога {threshold}")
                    st.markdown(f"**Текст фрагмента:**")
                    st.text(r['text'][:500] + ("..." if len(r['text']) > 500 else ""))
    
    # Если результатов нет
    elif not results:
        st.info("ℹ️ Не найдено релевантных фрагментов в базе знаний.")


# Информация для новых пользователей
elif not query:
    st.info("👋 Введите вопрос в поле выше или выберите один из demo-вопросов в боковой панели.")


# Footer
st.markdown("---")
st.caption(f"SupportRAG v1.0 | TF-IDF поиск | top_k={TOP_K} | threshold={SIMILARITY_THRESHOLD}")
