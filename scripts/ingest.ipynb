import json
import pandas as pd
from pathlib import Path

def ingest():
    
    input_path = "datasets.json"
    output_path = "documents.jsonl"
    
    
    print(f"Чтение: {input_path}")
    with open(input_path, 'r', encoding='utf-8') as f:
        data = json.load(f)
    
    documents = data.get("datasets", [])
    
    if not documents:
        raise ValueError(f"В файле нет ключа 'datasets' или массив пуст")
    
    print(f"Найдено документов: {len(documents)}")
    
    written_count = 0
    with open(output_path, 'w', encoding='utf-8') as f:
        for doc in documents:
            doc_id = doc.get("id")
            name = doc.get("title", "")
            text = doc.get("text", "")
            
            if not text:
                print(f"Пропущен документ {doc_id}: отсутствует текст")
                continue
            
            record = {
                "doc_id": doc_id,
                "name": name,
                "text": text,
                "source_file": "datasets.json"
            }
            
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
            written_count += 1
    
    print(f"Создано {written_count} документов в {output_path}")
    
    if written_count > 0:
        print("Пример первой записи в documents.jsonl:")
        with open(output_path, 'r', encoding='utf-8') as f:
            first_line = f.readline()
            example = json.loads(first_line)
            print(f"doc_id: {example['doc_id']}")
            print(f"name: {example['name'][:50]}...")
            print(f"text (первые 100 символов): {example['text'][:100]}...")
            print(f"source_file: {example['source_file']}")

ingest()
