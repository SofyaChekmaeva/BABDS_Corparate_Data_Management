import json
import pickle
from pathlib import Path

import numpy as np
import scipy.sparse as sp
from sklearn.feature_extraction.text import TfidfVectorizer

def build_index():
    
    # Создаём директорию для индекса
    input_path = "chunks.jsonl"
    
    # Загружаем чанки
    chunks = []
    chunk_infos = []  # сохраняем метаданные
    chunk_id_counter = 0
    
    with open(input_path, 'r', encoding='utf-8') as f:
        for line in f:
            if line.strip():
                chunk = json.loads(line)
                chunks.append(chunk.get('text', ''))
                chunk_infos.append({
                    "chunk_id": chunk.get('chunk_id'),
                    "doc_id": chunk.get('doc_id'),
                    "chunk_index": chunk.get('chunk_index'),
                    "name": chunk.get('name', '')
                })
                chunk_id_counter += 1
    
    print(f"Загружено чанков: {len(chunks)}")
    
    # Создаём и обучаем TF-IDF векторизатор
    print("\nСоздание TF-IDF векторизатора...")
    vectorizer = TfidfVectorizer(
        max_features=None,  # не ограничиваем количество признаков
        stop_words=None,     # можно добавить стоп-слова
        lowercase=True,
        token_pattern=r'(?u)\b\w+\b',
        min_df=1,            # термин должен встречаться хотя бы в 1 чанке
        max_df=1.0,          # нет верхнего предела
        sublinear_tf=True    # использование 1+log(tf)
    )
    
    print("Обучение векторизатора и трансформация чанков...")
    tfidf_matrix = vectorizer.fit_transform(chunks)
    
    # Получаем информацию о матрице
    n_chunks, n_features = tfidf_matrix.shape
    print(f"Размер TF-IDF матрицы: {n_chunks} чанков × {n_features} признаков")
    print(f"Плотность матрицы: {tfidf_matrix.nnz / (n_chunks * n_features) * 100:.2f}%")
    
    # Сохраняем векторизатор
    vectorizer_path = "vectorizer.pkl"
    with open(vectorizer_path, 'wb') as f:
        pickle.dump(vectorizer, f)
    print(f"✅ Векторизатор сохранён: {vectorizer_path}")
    
    # Сохраняем TF-IDF матрицу в разреженном формате
    matrix_path = "matrix.npz"
    sp.save_npz(matrix_path, tfidf_matrix)
    print(f"✅ TF-IDF матрица сохранена: {matrix_path}")
    
    # Сохраняем копию чанков с метаданными для поиска
    chunks_info_path = "chunks.jsonl"
    with open(chunks_info_path, 'w', encoding='utf-8') as f:
        for info in chunk_infos:
            f.write(json.dumps(info, ensure_ascii=False) + "\n")
    print(f"✅ Метаданные чанков сохранены: {chunks_info_path}")
    
    # Дополнительная статистика
    print("\n" + "="*50)
    print("СТАТИСТИКА ИНДЕКСА")
    print("="*50)
    print(f"Всего чанков: {n_chunks}")
    print(f"Всего уникальных термов: {n_features}")
    print(f"Средняя длина чанка: {sum(len(c) for c in chunks) / len(chunks):.1f} символов")
    print(f"Ненулевых элементов: {tfidf_matrix.nnz}")
    
    # Пример наиболее частых термов
    feature_names = vectorizer.get_feature_names_out()
    # Суммируем TF-IDF по всем чанкам
    term_freq = np.asarray(tfidf_matrix.sum(axis=0)).ravel()
    top_terms_idx = term_freq.argsort()[-10:][::-1]
    
    print("Топ-10 наиболее частых термов (по сумме TF-IDF):")
    for idx in top_terms_idx:
        print(f"   {feature_names[idx]}: {term_freq[idx]:.2f}")


build_index()
