import json
import pandas as pd
from pathlib import Path

def prepare_dataset(csv_path: str, n_records: int = 5000):
    print(f"Загрузка CSV-файла: {csv_path}")
    df = pd.read_csv(csv_path, nrows=n_records)
    
    print(f"Загружено записей: {len(df)}")
    print(f"Доступные колонки: {df.columns.tolist()}")
    
    # Формируем записи для RAG
    records = []
    skipped = 0
    
    for idx, row in df.iterrows():
        # Собираем текст для индексации
        text_parts = []
        
        if pd.notna(row.get('issue_description')):
            text_parts.append(row['issue_description'])
        
        if pd.notna(row.get('resolution_notes')):
            text_parts.append("Ответ поддержки: " + row['resolution_notes'])
        
        # Если нет ни описания, ни ответа — пропускаем
        if not text_parts:
            skipped += 1
            continue
        
        record = {
            "id": str(row.get('Ticket ID', idx)),
            "title": row.get('Ticket Category', 'Без категории'),
            "text": "\n\n".join(text_parts)
        }
        records.append(record)
    
    # Сохраняем в формате проекта (обёрнуто в ключ "datasets")
    output_path = "datasets.json"
    with open(output_path, 'w', encoding='utf-8') as f:
        json.dump({"datasets": records}, f, ensure_ascii=False, indent=2)
    
    print(f"\nСохранено {len(records)} записей в {output_path}")
    print(f"⏭Пропущено записей без текста: {skipped}")
    
    # Пример первой записи
    if records:
        print(f"Пример первой записи:")
        print(f"id: {records[0]['id']}")
        print(f"title: {records[0]['title']}")
        print(f"text (первые 200 символов): {records[0]['text'][:200]}...")

CSV_FILE = "customer_support_tickets_200k.csv"
prepare_dataset(str(CSV_FILE), n_records=5000)
